{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build:shared && npm run build:client",
  "outputDirectory": "packages/client/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
