# BLOOM — environment for a PURE-SERVERLESS (Vercel) deploy.
# Set these in Vercel → Project → Settings → Environment Variables (Production).
# (For local dev with zero infra, use .env.example instead — STORAGE/CACHE=memory.)

# --- runtime ---
NODE_ENV=production

# --- data: serverless REQUIRES shared state. In-memory adapters lose the
#     nonce/replay window and rate-limit counters between the isolated function
#     invocations, which would break anti-cheat — so Postgres + Redis are required.
STORAGE=postgres
CACHE=redis

# Serverless Postgres — use the POOLED connection string (Neon pooler / Supabase
# pgbouncer / Vercel Postgres). Example (Neon):
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Serverless Redis — Upstash speaks the Redis protocol over a rediss:// URL:
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# Schema bootstrap runs as a one-off deploy step (`npm run db:migrate`), NOT on
# every cold start. The serverless function pins this off regardless.
AUTO_MIGRATE=false

# --- secrets: MUST be 16+ chars; production refuses to boot on the dev value.
#     Generate each with:  openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32
HMAC_SECRET=change-me-openssl-rand-hex-32
RNG_SALT=change-me-openssl-rand-hex-32

# --- client build vars (Vercel injects at build; VITE_HMAC_SECRET MUST equal
#     the server HMAC_SECRET above). Same-origin API → leave VITE_API_BASE blank.
VITE_API_BASE=
VITE_HMAC_SECRET=change-me-match-HMAC_SECRET
VITE_APP_VERSION=0.1.0
# VITE_REALTIME stays unset → WebSockets off → pure HTTP polling.

# --- optional: IAP receipt validation ---
# APPLE_SHARED_SECRET=
# GOOGLE_SERVICE_ACCOUNT_JSON=
